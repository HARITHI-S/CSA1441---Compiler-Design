#include <stdio.h>
#include <string.h>

int main() {
    char p1[] = "iEtS";
    char p2[] = "iEtSeS";
    char p3[] = "a";
    char common[20], rem1[20], rem2[20];
    int i = 0, j = 0;

    while (p1[i] && p2[i] && p1[i] == p2[i]) {
        common[i] = p1[i];
        i++;
    }
    common[i] = '\0';

    strcpy(rem1, p1 + i);
    strcpy(rem2, p2 + i);

    printf("After left factoring:\n");
    printf("S  -> %sS' | %s\n", common, p3);

    if (strlen(rem1) == 0)
        strcpy(rem1, "@");

    if (strlen(rem2) == 0)
        strcpy(rem2, "@");

    printf("S' -> %s | %s\n", rem1, rem2);
    printf("E  -> b\n");

    return 0;
}
