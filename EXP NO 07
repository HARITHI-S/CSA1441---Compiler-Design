#include <stdio.h>
#include <ctype.h>

void first(char x) {
    if (x == 'A' || x == 'B')
        printf("e ");
    else if (x == 'S')
        printf("a b ");
    else if (!isupper(x))
        printf("%c ", x);
}

int main() {
    printf("FIRST(A) = { ");
    first('A');
    printf("}\n");

    printf("FIRST(B) = { ");
    first('B');
    printf("}\n");

    printf("FIRST(S) = { ");
    first('S');
    printf("}\n");

    return 0;
}
