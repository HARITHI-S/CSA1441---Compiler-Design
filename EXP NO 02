#include <stdio.h>
#include <string.h>

int main() {
    char line[] = "//* This is a comment *//";
    int n = strlen(line);

    if (line[0] == '/' && line[1] == '/') {
        printf("It is a single line comment");
    }
    else if (line[0] == '/' && line[1] == '*' && line[n-2] == '*' && line[n-1] == '/') {
        printf("It is a multi line comment");
    }
    else {
        printf("It is not a comment");
    }

    return 0;
}
