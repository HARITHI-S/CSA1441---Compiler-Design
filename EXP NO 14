#include <stdio.h>
#include <string.h>

int main() {
    char exp[20], t1[10], t2[10];
    int i = 0;
    int temp_count = 1;

    printf("Enter expression (e.g., a = b + c * d): ");
    fgets(exp, sizeof(exp), stdin);
    exp[strcspn(exp, "\n")] = 0;

    while (exp[i] != '=' && exp[i] != '\0')
        i++;

    if (exp[i] != '=' || i == 0) {
        printf("Invalid expression\n");
        return 0;
    }

    i++;

    snprintf(t1, sizeof(t1), "t%d", temp_count++);
    snprintf(t2, sizeof(t2), "t%d", temp_count++);

    printf("Three address code:\n");
    printf("%s = %c * %c\n", t1, exp[i+3], exp[i+5]);   
    printf("%s = %c + %s\n", t2, exp[i+1], t1);
    printf("%c = %s\n", exp[0], t2);  

    return 0;
}
